From ee016c883bacff42af1e95137da44a0430f633c4 Mon Sep 17 00:00:00 2001
From: Guillaume Ausset <guillaume@ausset.me>
Date: Mon, 23 Feb 2026 15:13:22 +0100
Subject: [PATCH 1/3] extmod/bluetooth: add dedicated disconnect reason IRQ
 (32)

---
 extmod/modbluetooth.c               | 19 +++++++++++++++++++
 extmod/modbluetooth.h               |  7 +++++++
 extmod/nimble/modbluetooth_nimble.c |  4 ++++
 3 files changed, 30 insertions(+)

diff --git a/extmod/modbluetooth.c b/extmod/modbluetooth.c
index ffa407809..bb99dcafb 100644
--- a/extmod/modbluetooth.c
+++ b/extmod/modbluetooth.c
@@ -1081,6 +1081,9 @@ static mp_obj_t bluetooth_ble_invoke_irq(mp_obj_t none_in) {
         if (event == MP_BLUETOOTH_IRQ_CENTRAL_CONNECT || event == MP_BLUETOOTH_IRQ_PERIPHERAL_CONNECT || event == MP_BLUETOOTH_IRQ_CENTRAL_DISCONNECT || event == MP_BLUETOOTH_IRQ_PERIPHERAL_DISCONNECT) {
             // conn_handle, addr_type, addr
             ringbuf_extract(&o->ringbuf, data_tuple, 1, 1, &o->irq_data_addr, 0, NULL, NULL);
+        } else if (event == MP_BLUETOOTH_IRQ_DISCONNECT_REASON) {
+            // disconnect_event, conn_handle, reason
+            ringbuf_extract(&o->ringbuf, data_tuple, 2, 1, NULL, 0, NULL, NULL);
         } else if (event == MP_BLUETOOTH_IRQ_CONNECTION_UPDATE) {
             // conn_handle, conn_interval, conn_latency, supervision_timeout, status
             ringbuf_extract(&o->ringbuf, data_tuple, 5, 0, NULL, 0, NULL, NULL);
@@ -1314,6 +1317,11 @@ void mp_bluetooth_gap_on_connected_disconnected(uint8_t event, uint16_t conn_han
     invoke_irq_handler(event, args, 2, 0, addr, NULL_UUID, NULL_DATA, NULL_DATA_LEN, 0);
 }
 
+void mp_bluetooth_gap_on_disconnect_reason(uint8_t disconnect_event, uint16_t conn_handle, uint8_t reason) {
+    mp_int_t args[] = {disconnect_event, conn_handle, reason};
+    invoke_irq_handler(MP_BLUETOOTH_IRQ_DISCONNECT_REASON, args, 3, 0, NULL_ADDR, NULL_UUID, NULL_DATA, NULL_DATA_LEN, 0);
+}
+
 void mp_bluetooth_gap_on_connection_update(uint16_t conn_handle, uint16_t conn_interval, uint16_t conn_latency, uint16_t supervision_timeout, uint16_t status) {
     mp_int_t args[] = {conn_handle, conn_interval, conn_latency, supervision_timeout, status};
     invoke_irq_handler(MP_BLUETOOTH_IRQ_CONNECTION_UPDATE, args, 5, 0, NULL_ADDR, NULL_UUID, NULL_DATA, NULL_DATA_LEN, 0);
@@ -1514,6 +1522,17 @@ void mp_bluetooth_gap_on_connected_disconnected(uint8_t event, uint16_t conn_han
     schedule_ringbuf(atomic_state);
 }
 
+void mp_bluetooth_gap_on_disconnect_reason(uint8_t disconnect_event, uint16_t conn_handle, uint8_t reason) {
+    MICROPY_PY_BLUETOOTH_ENTER
+    mp_obj_bluetooth_ble_t *o = MP_OBJ_TO_PTR(MP_STATE_VM(bluetooth));
+    if (enqueue_irq(o, 1 + 2 + 1, MP_BLUETOOTH_IRQ_DISCONNECT_REASON)) {
+        ringbuf_put(&o->ringbuf, disconnect_event);
+        ringbuf_put16(&o->ringbuf, conn_handle);
+        ringbuf_put(&o->ringbuf, reason);
+    }
+    schedule_ringbuf(atomic_state);
+}
+
 void mp_bluetooth_gap_on_connection_update(uint16_t conn_handle, uint16_t conn_interval, uint16_t conn_latency, uint16_t supervision_timeout, uint16_t status) {
     MICROPY_PY_BLUETOOTH_ENTER
     mp_obj_bluetooth_ble_t *o = MP_OBJ_TO_PTR(MP_STATE_VM(bluetooth));
diff --git a/extmod/modbluetooth.h b/extmod/modbluetooth.h
index 24f063fa5..4f03b6b49 100644
--- a/extmod/modbluetooth.h
+++ b/extmod/modbluetooth.h
@@ -161,6 +161,9 @@
 #define MP_BLUETOOTH_IRQ_GET_SECRET                     (29)
 #define MP_BLUETOOTH_IRQ_SET_SECRET                     (30)
 #define MP_BLUETOOTH_IRQ_PASSKEY_ACTION                 (31)
+// Provides controller/stack disconnect reason as a separate IRQ payload:
+// (disconnect_event, conn_handle, reason).
+#define MP_BLUETOOTH_IRQ_DISCONNECT_REASON              (32)
 
 #define MP_BLUETOOTH_ADDRESS_MODE_PUBLIC (0)
 #define MP_BLUETOOTH_ADDRESS_MODE_RANDOM (1)
@@ -226,6 +229,7 @@ _IRQ_ENCRYPTION_UPDATE = const(28)
 _IRQ_GET_SECRET = const(29)
 _IRQ_SET_SECRET = const(30)
 _IRQ_PASSKEY_ACTION = const(31)
+_IRQ_DISCONNECT_REASON = const(32)
 
 _FLAG_BROADCAST = const(0x0001)
 _FLAG_READ = const(0x0002)
@@ -415,6 +419,9 @@ int mp_bluetooth_hci_cmd(uint16_t ogf, uint16_t ocf, const uint8_t *req, size_t
 // Notify modbluetooth that a connection/disconnection event has occurred.
 void mp_bluetooth_gap_on_connected_disconnected(uint8_t event, uint16_t conn_handle, uint8_t addr_type, const uint8_t *addr);
 
+// Notify modbluetooth of a low-level disconnect reason for a disconnect event.
+void mp_bluetooth_gap_on_disconnect_reason(uint8_t disconnect_event, uint16_t conn_handle, uint8_t reason);
+
 // Call this when any connection parameters have been changed.
 void mp_bluetooth_gap_on_connection_update(uint16_t conn_handle, uint16_t conn_interval, uint16_t conn_latency, uint16_t supervision_timeout, uint16_t status);
 
diff --git a/extmod/nimble/modbluetooth_nimble.c b/extmod/nimble/modbluetooth_nimble.c
index 5e7030e36..9fcf2ae63 100644
--- a/extmod/nimble/modbluetooth_nimble.c
+++ b/extmod/nimble/modbluetooth_nimble.c
@@ -455,6 +455,7 @@ static int central_gap_event_cb(struct ble_gap_event *event, void *arg) {
                 mp_bluetooth_gap_on_connected_disconnected(MP_BLUETOOTH_IRQ_CENTRAL_CONNECT, event->connect.conn_handle, desc.peer_id_addr.type, addr);
             } else {
                 // Connection failed.
+                mp_bluetooth_gap_on_disconnect_reason(MP_BLUETOOTH_IRQ_CENTRAL_DISCONNECT, event->connect.conn_handle, event->connect.status);
                 mp_bluetooth_gap_on_connected_disconnected(MP_BLUETOOTH_IRQ_CENTRAL_DISCONNECT, event->connect.conn_handle, 0xff, addr);
             }
             return 0;
@@ -463,6 +464,7 @@ static int central_gap_event_cb(struct ble_gap_event *event, void *arg) {
             // Disconnect.
             DEBUG_printf("central_gap_event_cb: disconnect: reason=%d\n", event->disconnect.reason);
             reverse_addr_byte_order(addr, event->disconnect.conn.peer_id_addr.val);
+            mp_bluetooth_gap_on_disconnect_reason(MP_BLUETOOTH_IRQ_CENTRAL_DISCONNECT, event->disconnect.conn.conn_handle, event->disconnect.reason);
             mp_bluetooth_gap_on_connected_disconnected(MP_BLUETOOTH_IRQ_CENTRAL_DISCONNECT, event->disconnect.conn.conn_handle, event->disconnect.conn.peer_id_addr.type, addr);
             return 0;
 
@@ -1217,6 +1219,7 @@ static int peripheral_gap_event_cb(struct ble_gap_event *event, void *arg) {
                 mp_bluetooth_gap_on_connected_disconnected(MP_BLUETOOTH_IRQ_PERIPHERAL_CONNECT, event->connect.conn_handle, desc.peer_id_addr.type, addr);
             } else {
                 // Connection failed.
+                mp_bluetooth_gap_on_disconnect_reason(MP_BLUETOOTH_IRQ_PERIPHERAL_DISCONNECT, event->connect.conn_handle, event->connect.status);
                 mp_bluetooth_gap_on_connected_disconnected(MP_BLUETOOTH_IRQ_PERIPHERAL_DISCONNECT, event->connect.conn_handle, 0xff, addr);
             }
             return 0;
@@ -1225,6 +1228,7 @@ static int peripheral_gap_event_cb(struct ble_gap_event *event, void *arg) {
             // Disconnect.
             DEBUG_printf("peripheral_gap_event_cb: reason=%d\n", event->disconnect.reason);
             reverse_addr_byte_order(addr, event->disconnect.conn.peer_id_addr.val);
+            mp_bluetooth_gap_on_disconnect_reason(MP_BLUETOOTH_IRQ_PERIPHERAL_DISCONNECT, event->disconnect.conn.conn_handle, event->disconnect.reason);
             mp_bluetooth_gap_on_connected_disconnected(MP_BLUETOOTH_IRQ_PERIPHERAL_DISCONNECT, event->disconnect.conn.conn_handle, event->disconnect.conn.peer_id_addr.type, addr);
             return 0;
     }
