{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "_fw-rp2-common",
      "hidden": true,
      "binaryDir": "${fileDir}/build/${presetName}",
      "cacheVariables": {
        "POLAR_ENABLE_HR": "ON",
        "POLAR_ENABLE_ECG": "ON",
        "POLAR_ENABLE_PSFTP": "ON",
        "POLAR_VERIFY_MICROPY_PATCHES": "ON",
        "POLAR_AUTO_APPLY_PATCHES": "ON",
        "PICO_BUILD_DOCS": "0",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "_fw-rp2-release",
      "hidden": true,
      "inherits": ["_fw-rp2-common"],
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "MinSizeRel"
      }
    },
    {
      "name": "fw-pico2w",
      "displayName": "Firmware Pico 2 W: polar_sdk module",
      "inherits": ["_fw-rp2-release"],
      "binaryDir": "${fileDir}/build/mpy-pico2w",
      "cacheVariables": {
        "MICROPY_BOARD": "RPI_PICO2_W",
        "MICROPY_BOARD_DIR": "${fileDir}/vendors/micropython/ports/rp2/boards/RPI_PICO2_W",
        "USER_C_MODULES": "${fileDir}/polar_sdk/mpy",
        "POLAR_BUILD_PRESET_NAME": "fw-pico2w",
        "POLAR_ARTIFACTS_PROFILE": "fw-pico2w"
      }
    },
    {
      "name": "fw-pico2w-picographics",
      "displayName": "Firmware Pico 2 W: polar_sdk + minimal Pimoroni picographics",
      "inherits": ["_fw-rp2-release"],
      "binaryDir": "${fileDir}/build/mpy-pico2w-picographics",
      "cacheVariables": {
        "MICROPY_BOARD": "RPI_PICO2_W",
        "MICROPY_BOARD_DIR": "${fileDir}/vendors/micropython/ports/rp2/boards/RPI_PICO2_W",
        "USER_C_MODULES": "${fileDir}/polar_sdk/mpy;${fileDir}/firmware/cmake/pimoroni_minimal.cmake",
        "MICROPY_C_HEAP_SIZE": "8192",
        "POLAR_BUILD_PRESET_NAME": "fw-pico2w-picographics",
        "POLAR_ARTIFACTS_PROFILE": "fw-pico2w-picographics"
      }
    },
    {
      "name": "fw-rp2-1",
      "displayName": "Firmware RP2-1: polar_sdk module",
      "inherits": ["_fw-rp2-release"],
      "binaryDir": "${fileDir}/build/mpy-rp2-1",
      "cacheVariables": {
        "MICROPY_BOARD": "RP2_1",
        "MICROPY_BOARD_DIR": "${fileDir}/firmware/boards/RP2_1",
        "MICROPY_C_HEAP_SIZE": "8192",
        "USER_C_MODULES": "${fileDir}/polar_sdk/mpy;${fileDir}/firmware/cmake/pimoroni_rtc_minimal.cmake",
        "POLAR_BUILD_PRESET_NAME": "fw-rp2-1",
        "POLAR_ARTIFACTS_PROFILE": "fw-rp2-1"
      }
    },
    {
      "name": "fw-rp2-1-debug",
      "displayName": "Firmware RP2-1: polar_sdk module (debug)",
      "inherits": ["fw-rp2-1"],
      "binaryDir": "${fileDir}/build/mpy-rp2-1-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "POLAR_BUILD_PRESET_NAME": "fw-rp2-1-debug",
        "POLAR_ARTIFACTS_PROFILE": "fw-rp2-1-debug"
      }
    },
    {
      "name": "fw-rp2-2",
      "displayName": "Firmware RP2-2: polar_sdk module",
      "inherits": ["_fw-rp2-release"],
      "binaryDir": "${fileDir}/build/mpy-rp2-2",
      "cacheVariables": {
        "MICROPY_BOARD": "RP2_2",
        "MICROPY_BOARD_DIR": "${fileDir}/firmware/boards/RP2_2",
        "USER_C_MODULES": "${fileDir}/polar_sdk/mpy",
        "POLAR_BUILD_PRESET_NAME": "fw-rp2-2",
        "POLAR_ARTIFACTS_PROFILE": "fw-rp2-2"
      }
    },
    {
      "name": "fw-rp2-2-debug",
      "displayName": "Firmware RP2-2: polar_sdk module (debug)",
      "inherits": ["fw-rp2-2"],
      "binaryDir": "${fileDir}/build/mpy-rp2-2-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "POLAR_BUILD_PRESET_NAME": "fw-rp2-2-debug",
        "POLAR_ARTIFACTS_PROFILE": "fw-rp2-2-debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "fw-pico2w",
      "configurePreset": "fw-pico2w",
      "jobs": 0
    },
    {
      "name": "fw-pico2w-picographics",
      "configurePreset": "fw-pico2w-picographics",
      "jobs": 0
    },
    {
      "name": "fw-rp2-1",
      "configurePreset": "fw-rp2-1",
      "jobs": 0
    },
    {
      "name": "fw-rp2-1-debug",
      "configurePreset": "fw-rp2-1-debug",
      "jobs": 0
    },
    {
      "name": "fw-rp2-2",
      "configurePreset": "fw-rp2-2",
      "jobs": 0
    },
    {
      "name": "fw-rp2-2-debug",
      "configurePreset": "fw-rp2-2-debug",
      "jobs": 0
    }
  ],
  "workflowPresets": [
    {
      "name": "wf-fw-pico2w",
      "displayName": "Configure+build Pico 2 W polar_sdk firmware",
      "steps": [
        {
          "type": "configure",
          "name": "fw-pico2w"
        },
        {
          "type": "build",
          "name": "fw-pico2w"
        }
      ]
    },
    {
      "name": "wf-fw-pico2w-picographics",
      "displayName": "Configure+build Pico 2 W polar+picographics firmware",
      "steps": [
        {
          "type": "configure",
          "name": "fw-pico2w-picographics"
        },
        {
          "type": "build",
          "name": "fw-pico2w-picographics"
        }
      ]
    },
    {
      "name": "wf-fw-rp2-1",
      "displayName": "Configure+build RP2-1 polar_sdk firmware",
      "steps": [
        {
          "type": "configure",
          "name": "fw-rp2-1"
        },
        {
          "type": "build",
          "name": "fw-rp2-1"
        }
      ]
    },
    {
      "name": "wf-fw-rp2-1-debug",
      "displayName": "Configure+build RP2-1 polar_sdk firmware (debug)",
      "steps": [
        {
          "type": "configure",
          "name": "fw-rp2-1-debug"
        },
        {
          "type": "build",
          "name": "fw-rp2-1-debug"
        }
      ]
    },
    {
      "name": "wf-fw-rp2-2",
      "displayName": "Configure+build RP2-2 polar_sdk firmware",
      "steps": [
        {
          "type": "configure",
          "name": "fw-rp2-2"
        },
        {
          "type": "build",
          "name": "fw-rp2-2"
        }
      ]
    },
    {
      "name": "wf-fw-rp2-2-debug",
      "displayName": "Configure+build RP2-2 polar_sdk firmware (debug)",
      "steps": [
        {
          "type": "configure",
          "name": "fw-rp2-2-debug"
        },
        {
          "type": "build",
          "name": "fw-rp2-2-debug"
        }
      ]
    }
  ]
}
